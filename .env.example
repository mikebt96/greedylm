# GENERAL
ENVIRONMENT=local # set to 'production' on deploy
DEBUG=true

# DATABASE (Local Docker default)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:15432/greedylm

# REDIS (Local Docker default)
REDIS_URL=redis://localhost:6379/0

# QDRANT (Local Docker default)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# SECURITY
JWT_SECRET=generate-a-safe-secret-with-openssl-rand-hex-32
ENCRYPTION_KEY=generate-a-safe-key-at-least-32-chars
MASTER_KEY_HASH= # Generate with passlib.hash.bcrypt.hash("your-key")

# STRIPE
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OAUTH - GOOGLE
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAUTH - GITHUB
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# LLM PROVIDERS
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# EMAIL (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# FRONTEND
FRONTEND_URL=http://localhost:3000

# CLOUD FLAGS
RENDER=false
